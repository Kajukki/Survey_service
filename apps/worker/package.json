{
  "name": "@survey-service/worker",
  "version": "0.0.0",
  "private": true,
  "description": "RabbitMQ consumers — provider sync and analysis rollups (scale horizontally)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@survey-service/connectors": "file:../../packages/connectors",
    "@survey-service/messaging": "file:../../packages/messaging",
    "amqplib": "^0.10.3",
    "dotenv": "^17.4.0",
    "pg": "^8.11.3",
    "pino": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.20.5",
    "vitest": "^1.6.1"
  }
}
