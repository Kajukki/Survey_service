# Development Environment Variables
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/surveyservice
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_PREFETCH=10

# Authentication (MOCK for local development)
OIDC_ISSUER=http://localhost/mock-issuer
OIDC_AUDIENCE=survey-api
OIDC_JWKS_URI=http://localhost/mock-jwks
AUTH_JWT_SECRET=replace-this-with-a-long-dev-only-secret-at-least-32-chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_AUTH_BASE_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_FORMS_API_BASE_URL=https://forms.googleapis.com/v1
GOOGLE_OAUTH_ALLOWED_SCOPES=https://www.googleapis.com/auth/forms.body.readonly,https://www.googleapis.com/auth/forms.responses.readonly

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Features
ENABLE_RATE_LIMITING=true
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
