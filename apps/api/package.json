{
  "name": "@survey-service/api",
  "version": "0.0.0",
  "private": true,
  "description": "REST/BFF — authentication, owner/share authorization, enqueue jobs to RabbitMQ",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^6.0.4",
    "@survey-service/connectors": "file:../../packages/connectors",
    "@survey-service/contracts": "file:../../packages/contracts",
    "@survey-service/db": "file:../../packages/db",
    "@survey-service/messaging": "file:../../packages/messaging",
    "@survey-service/shared": "file:../../packages/shared",
    "amqplib": "^0.10.3",
    "dotenv": "^17.4.0",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^5.4.1",
    "kysely": "^0.27.2",
    "pg": "^8.11.3",
    "pino": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.20.5",
    "vitest": "^1.6.0"
  }
}
